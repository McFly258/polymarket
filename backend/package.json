{
  "name": "polymarket-paper-backend",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS backend for the Polymarket paper-trading engine (Postgres/Prisma).",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --max-warnings 0 src",
    "lint:fix": "yarn lint --fix",
    "check-types": "tsc --noEmit",
    "seed:from-sqlite": "tsx scripts/seed-from-sqlite.ts"
  },
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.15",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/platform-ws": "10.4.15",
    "@nestjs/swagger": "8.1.1",
    "@nestjs/websockets": "10.4.15",
    "@polymarket/clob-client-v2": "^1.0.2",
    "@prisma/client": "5.22.0",
    "@scalar/nestjs-api-reference": "0.5.4",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.12.0",
    "@types/ws": "8.18.1",
    "better-sqlite3": "12.9.0",
    "eslint": "9.39.4",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.9.3"
  }
}

NODE_ENV=development
PORT=7802
HOST=127.0.0.1
DATABASE_URL=postgresql://polymarket_nest:polymarket_nest_dev@127.0.0.1:5433/polymarket_paper?schema=public
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Real execution — off by default. Flip ENABLE_REAL_EXECUTION=true to dispatch
# to Polymarket CLOB. Paused flag in real_execution_state table overrides.
ENABLE_REAL_EXECUTION=false
CLOB_WALLET_ADDRESS=your-wallet-address-here
CLOB_API_KEY=your-api-key-here
CLOB_API_SECRET=your-api-secret-here
CLOB_API_PASSPHRASE=your-passphrase-here
REAL_MAX_DAILY_LOSS_USD=100
REAL_MAX_NOTIONAL_USD=5000
